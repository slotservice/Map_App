{
  "name": "map-app",
  "version": "0.1.0",
  "private": true,
  "description": "Full Circle Map App — monorepo (api + admin + mobile + shared)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" build",
    "dev": "pnpm --parallel --filter \"./apps/api\" --filter \"./apps/admin\" dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml}\"",
    "infra:up": "node infra/up.mjs",
    "infra:down": "node infra/down.mjs",
    "infra:up:docker": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down:docker": "docker compose -f infra/docker-compose.yml down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.10.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yml,yaml}": ["prettier --write"]
  }
}
