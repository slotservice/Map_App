# Root .env — only used by docker-compose.yml + scripts in /infra.
# Per-app env vars live in apps/*/.env.example. Copy this to .env locally.

# Postgres (local Docker)
POSTGRES_USER=mapapp
POSTGRES_PASSWORD=mapapp_dev_only
POSTGRES_DB=mapapp_dev
POSTGRES_PORT=5432

# MinIO (local S3-compatible storage; production uses Cloudflare R2)
MINIO_ROOT_USER=mapapp
MINIO_ROOT_PASSWORD=mapapp_dev_only
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DEFAULT_BUCKET=fcfm-photos-dev

# Mailhog (local email capture)
MAILHOG_SMTP_PORT=1025
MAILHOG_HTTP_PORT=8025
