# Source: legacy MariaDB. Use a read-only user and a dump replica when possible.
LEGACY_DB_HOST=localhost
LEGACY_DB_PORT=3306
LEGACY_DB_USER=postitri_storemanage
LEGACY_DB_PASSWORD=
LEGACY_DB_NAME=postitri_storemanage

# Source: legacy photo files (extracted from public_html.zip).
LEGACY_PHOTOS_DIR=./legacy/public_html/public

# Target: new Postgres.
DATABASE_URL=postgresql://mapapp:mapapp_dev_only@localhost:5432/mapapp_dev

# Target: object storage (R2 in prod, MinIO locally).
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=fcfm-photos-dev
S3_ACCESS_KEY=mapapp
S3_SECRET_KEY=mapapp_dev_only
S3_FORCE_PATH_STYLE=true

# Migration controls.
DRY_RUN=true
PHOTO_UPLOAD_CONCURRENCY=16
